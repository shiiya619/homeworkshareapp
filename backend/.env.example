# PostgreSQL接続URL。ローカルはdocker-compose(下記)の値をそのまま使える。
# 本番(Render)ではDBの接続文字列が自動注入される。
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/homeworkshareapp?schema=public"
PORT=3000

# フロントのオリジンを限定したい場合に設定（未設定なら全許可）
